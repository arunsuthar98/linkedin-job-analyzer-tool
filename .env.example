# Copy this file to .env and fill in your API keys.
# Never commit your actual .env file — it is listed in .gitignore.

# ── AI Provider (choose one or both) ─────────────────────────────────────
# Groq — FREE, no credit card needed (RECOMMENDED)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# OpenAI — optional alternative (paid, ~$0.01/search)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional but Recommended ──────────────────────────────────────────────
# JSearch API key via RapidAPI — enables live job postings (free tier)
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key_here

# YouTube Data API v3 key — enables video previews (free tier)
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=AIza...

# ── Tuneable Defaults ─────────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_MODEL=gpt-3.5-turbo
MAX_JOBS_PER_SEARCH=20
CACHE_TTL_SECONDS=3600
