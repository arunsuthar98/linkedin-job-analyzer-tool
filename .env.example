# Copy this file to .env and fill in your API keys.
# Never commit your actual .env file — it is listed in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────
# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ── Optional but Recommended ──────────────────────────────────────────────
# JSearch API key via RapidAPI — enables live job postings
# Free tier: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key_here

# YouTube Data API v3 key — enables embedded video previews
# Free tier: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=AIza...

# ── Tuneable Defaults ─────────────────────────────────────────────────────
# OpenAI model to use (gpt-3.5-turbo is cheaper; gpt-4o gives better results)
OPENAI_MODEL=gpt-3.5-turbo

# Maximum job postings to fetch per search
MAX_JOBS_PER_SEARCH=20

# How long (seconds) to cache job search results in-memory
CACHE_TTL_SECONDS=3600
